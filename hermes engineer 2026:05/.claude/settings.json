      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git remote *)",
      "Bash(git config *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git fetch *)",
      "Bash(git tag *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git rev-parse *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(gh auth *)",
      "Bash(gh repo *)",
      "Bash(gh api *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(touch *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(yarn *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pytest *)",
      "Bash(uv *)",
      "Bash(uvicorn *)",
      "Bash(mypy *)",
      "Bash(ruff *)",
      "Bash(alembic *)",
      "Bash(make *)",
      "Bash(curl *)",
      "Bash(docker-compose *)",
      "Bash(docker *)",
      "Bash(bash *)",
      "Bash(export *)",
      "Bash(set -e *)",
      "Read(//opt/homebrew/**)",
      "Read(//usr/local/**)",
      "Read(//Library/Frameworks/Python.framework/**)",
      "Read(//Users/leo/.claude/**)"
    ],
    "deny": [],
    "ask": [
      "Bash(rm *)",
      "Bash(git push --force*)",
      "Bash(gh repo delete*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post-write.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/on-stop.sh"
          }
        ]
      }
    ]
  }
}
